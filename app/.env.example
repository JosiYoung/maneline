# ---------------------------------------------------------------
# Mane Line SPA — local dev env
#
# Copy this file to `.env.local` and fill in real values. Never commit
# `.env.local`. In production, these values are injected by the Worker
# when the SPA is served (see wrangler.toml [vars]).
# ---------------------------------------------------------------

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe publishable key for Payment Elements (test-mode pk_test_...).
# Matches the STRIPE_SECRET_KEY Worker secret environment (test vs live).
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key_here
